use "$Data\census\census_provinces_byage\1940\dalava.dta", clear
gen province = "alava"
local provincedata ""albacete" "alicante" "almeria" "asturias" "avila" "badajoz" "baleares" "barcelona" "burgos" "caceres" "cadiz" "cantabria" "castellon" "ciudadreal" "cordoba" "coruna" "cuenca" "girona" "granada" "guadalajara" "guipuzcoa" "huelva" "huesca" "jaen" "leon" "lleida" "lugo" "madrid" "malaga" "murcia" "navarra" "ourense" "palencia" "laspalmas" "pontevedra" "larioja" "salamanca" "tenerife" "segovia" "sevilla" "soria" "tarragona" "teruel" "toledo" "valencia" "valladolid" "vizcaya" "zamora" "zaragoza" "ceuta" "melilla""
 foreach x of local provincedata{ 
append using "$Data\census\census_provinces_byage\1940\d`x'.dta"
replace province = "`x'" if province ==""
erase "$Data\census\census_provinces_byage\1940\d`x'.dta"
}
erase "$Data\census\census_provinces_byage\1940\dalava.dta"
gen year = 1940

**# Province code #1
gen codprov =4 if province == "almeria" 
replace codprov =11 if province == "cadiz" 
replace codprov =14 if province == "cordoba"  
replace codprov =18 if province == "granada"  
replace codprov =21 if province == "huelva" 
replace codprov =23 if province == "jaen" 
replace codprov =29 if province == "malaga" 
replace codprov =41 if province == "sevilla" 
replace codprov =22 if province == "huesca" 
replace codprov =44 if province == "teruel" 
replace codprov =50 if province == "zaragoza"
replace codprov =33 if province == "asturias" 
replace codprov =7 if province == "baleares" 
replace codprov =35 if province == "laspalmas" 
replace codprov =38 if province == "tenerife" 
replace province = "santa cruz de tenerife" if province == "tenerife" 
replace codprov =39 if province == "cantabria" 
replace codprov =5 if province == "avila"
replace codprov =9 if province == "burgos" 
replace codprov =24 if province == "leon" 
replace codprov =34 if province == "palencia" 
replace codprov =37 if province == "salamanca" 
replace codprov =40 if province == "segovia" 
replace codprov =42 if province == "soria" 
replace codprov =47 if province == "valladolid"
replace codprov =49 if province == "zamora" 
replace codprov =2 if province == "albacete"
replace province = "ciudad real"  if province == "ciudadreal" 
replace codprov =13 if province == "ciudad real" 
replace codprov =16 if province == "cuenca" 
replace codprov =19 if province == "guadalajara"
replace codprov =45 if province == "toledo"
replace codprov =8 if province == "barcelona" 
replace codprov =17 if province == "girona" 
replace codprov =25 if province == "lleida" 
replace codprov =43 if province == "tarragona"
replace codprov =3 if province == "alicante" 
replace codprov =12 if province == "castellon" 
replace codprov =46 if province == "valencia" 
replace codprov =6 if province == "badajoz" 
replace codprov =10 if province == "caceres" 
replace province = "a coruña"  if province == "coruna" 
replace codprov =15 if province == "a coruña"
replace codprov =27 if province == "lugo"
replace codprov =32 if province == "ourense"
replace codprov =36 if province == "pontevedra" 
replace codprov =28 if province == "madrid"
replace codprov =30 if province == "murcia"
replace codprov =31 if province == "navarra" 
replace codprov =1 if province == "alava" 
replace codprov =48 if province == "vizcaya"
replace codprov =20 if province == "guipuzcoa"
replace codprov =26 if province == "larioja"
replace codprov =51 if province == "ceuta"
replace codprov =52 if province == "melilla"

rename A age
rename B total
rename C men
rename D women
order year codprov province
sort codprov 

by codprov: egen pop_total = sum(total)
by codprov: egen popmen = sum(men)
by codprov: egen popwomen = sum(women)

replace age=trim(age) //remove blanks
replace age = "101" if age =="100 y más"
replace age = "." if age =="No consta"

destring age, replace
sort year codprov age

sort codprov

save "$Data\census\census_provinces_byage\1940\raw_census.dta", replace
**#
use "$Data\census\census_provinces_byage\1940\raw_census.dta", clear
* Create age groups according to the data on capital of province 
* total
by codprov: egen pop_agegroup = sum(total) if age <5 // 5-14
by codprov: replace pop_agegroup = sum(total) if age >=5 & age <15 // 5-14
by codprov: replace pop_agegroup = sum(total) if age >=15 & age <= 24
by codprov: replace pop_agegroup = sum(total) if age >=25 & age <= 34
by codprov: replace pop_agegroup = sum(total) if age >=35 & age <= 44
by codprov: replace pop_agegroup = sum(total) if age >=45 & age <= 54
by codprov: replace pop_agegroup = sum(total) if age >=55 & age <= 64
by codprov: replace pop_agegroup = sum(total) if age >=65 & age <= 74
by codprov: replace pop_agegroup = sum(total) if age >=75 & age <= 84
by codprov: replace pop_agegroup = sum(total) if age >=85 & age <= 94
by codprov: replace pop_agegroup = sum(total) if age >=95 & age <= 99
by codprov: replace pop_agegroup = sum(total) if age >=100
* men
by codprov: egen popmen_agegroup = sum(men) if age <5 // 5-14
by codprov: replace popmen_agegroup = sum(men) if age >=5 & age <15 // 5-14
by codprov: replace popmen_agegroup = sum(men) if age >=15 & age <= 24
by codprov: replace popmen_agegroup = sum(men) if age >=25 & age <= 34
by codprov: replace popmen_agegroup = sum(men) if age >=35 & age <= 44
by codprov: replace popmen_agegroup = sum(men) if age >=45 & age <= 54
by codprov: replace popmen_agegroup = sum(men) if age >=55 & age <= 64
by codprov: replace popmen_agegroup = sum(men) if age >=65 & age <= 74
by codprov: replace popmen_agegroup = sum(men) if age >=75 & age <= 84
by codprov: replace popmen_agegroup = sum(men) if age >=85 & age <= 94
by codprov: replace popmen_agegroup = sum(men) if age >=95 & age <= 99
by codprov: replace popmen_agegroup = sum(men) if age >=100
* women
by codprov: egen popwomen_agegroup = sum(women) if age <5 // 5-14
by codprov: replace popwomen_agegroup = sum(women) if age >=5 & age <15 // 5-14
by codprov: replace popwomen_agegroup = sum(women) if age >=15 & age <= 24
by codprov: replace popwomen_agegroup = sum(women) if age >=25 & age <= 34
by codprov: replace popwomen_agegroup = sum(women) if age >=35 & age <= 44
by codprov: replace popwomen_agegroup = sum(women) if age >=45 & age <= 54
by codprov: replace popwomen_agegroup = sum(women) if age >=55 & age <= 64
by codprov: replace popwomen_agegroup = sum(women) if age >=65 & age <= 74
by codprov: replace popwomen_agegroup = sum(women) if age >=75 & age <= 84
by codprov: replace popwomen_agegroup = sum(women) if age >=85 & age <= 94
by codprov: replace popwomen_agegroup = sum(women) if age >=95 & age <= 99
by codprov: replace popwomen_agegroup = sum(women) if age >=100
order codprov age total pop_agegroup
keep if age == 4|age == 14|age == 24|age == 34|age == 44|age == 54|age == 64|age == 74|age == 84|age == 94|age == 99
order codprov age total pop_agegroup 

*by codprov: egen share_treated = sum(age_share) if age >=5 & age <15 // 5-14
*label variable share_treated "Share Treated Primary School" 
keep year codprov province pop_agegroup* popmen_agegroup* popwomen_agegroup* popwomen popmen pop_total

