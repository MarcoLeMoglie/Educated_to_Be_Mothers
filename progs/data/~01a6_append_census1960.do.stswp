rename pop_total pop_1960 
rename pop_female pop_female_1960 
rename pop_male pop_male_1960 
label variable pop_1960 "Population 1960"
label variable pop_female_1960 "Female population 1960"
label variable pop_male_1960 "Male population 1960"
