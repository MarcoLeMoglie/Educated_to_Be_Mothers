sort province type sex
egen id = group(province type)
egen Sex = group(sex)
order id  sex type

reshape wide total type sex group* , i(id) j(Sex)


order province
rename total1 pop_male
rename total2 pop_total
rename total3 pop_female
drop sex* type2 type3 
rename type1 type
rename group(#)1 group(#)_male
rename group(#)2 group(#)_total
rename group(#)3 group(#)_female
 
drop id  
order prov type pop* codprov


foreach v of numlist 1/8{
rename group`v'_female popwomen_agegroup`v'_1960
rename group`v'_male popmen_agegroup`v'_1960
rename group`v'_total pop_agegroup`v'_1960

}


* Compute Pop share by age groups
local group ""1" "2" "3" "4" "5" "6" "7" "8""
 foreach x of local group{ 
bysort codprov: gen popshare_agegroup`x' =pop_agegroup`x'/ pop_total if province !="burgos"
bysort codprov: gen popsharemen_agegroup`x' =popmen_agegroup`x'/ pop_male if province !="burgos" & province !="malaga" & province !="badajoz"
bysort codprov: gen popsharewomen_agegroup`x' =popwomen_agegroup`x'/ pop_female if province !="burgos" & province !="malaga" & province !="badajoz"

label variable popshare_agegroup`x' "Pop. share age gr.`x'"


rename popshare_agegroup`x' popshare_agegroup`x'_1960 
rename popsharemen_agegroup`x' popsharemen_agegroup`x'_1960 
rename popsharewomen_agegroup`x' popsharewomen_agegroup`x'_1960 
}


