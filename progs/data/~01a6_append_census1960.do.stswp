label var pop_agegroup2_1960 "Pop. 5-14"
label var pop_agegroup3_1960 "Pop. 15-24"
label var pop_agegroup4_1960 "Pop. 25-34"
label var pop_agegroup5_1960 "Pop. 35-44"
