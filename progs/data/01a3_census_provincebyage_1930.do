egen pwomen_agegroup9 = rowtotal(women75- women84)
egen pwomen_agegroup10 = rowtotal(women85- women94)
egen pwomen_agegroup11 = rowtotal(women95- women101)
egen pwomen_agegroup12 = rowtotal(women102)
drop total* men* women* 

egen pop_total = rowtotal(pop_*)
egen pop_men_total = rowtotal(pmen*)
egen pop_women_total = rowtotal(pwomen*)

* Drop because it is missing in most of datasets:
drop pmen* pwomen* pop_men_total pop_women_total
save "$Data\census\census_provinces_byage\1930\census.dta", replace
 