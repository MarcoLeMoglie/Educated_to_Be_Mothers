}

twoway area group1 year, color(purple*0.1) || rarea group1 group2 year, color(purple*0.5) || rarea group2 group3 year, color(purple*0.9) || rarea group3 group4 year, color(purple*1.2) || rarea group4 group5 year, color(purple*1.8) || rarea group5 group6  year, color(purple*2.2) || rarea group6 group7 year, color(purple*5) || rarea group7 group8 year, color(purple*10.0) legend(order(1 "Below 5 years old" 2  "6-14 years old"  3  "15-24 years old"  4  "25-34 years old" 5 "35-44 years old"  6 "45-54 years old" 7 "55-64 years old" 8 "Above 65") pos(6) col(4)) xtitle("") xla(1930(10)1970) ytitle(Percent)
graph export "$Results/gr_age/treated/women.png",replace

